# Copy this file to `.env.local` (same folder) and fill in values.
# Next.js reads env files from THIS directory (apps/main), not the repo root.
# `pnpm setup-project` writes .env.local for you based on your answers.
#
# Only NEXT_PUBLIC_* variables are exposed to the browser.

# Active auth provider (informational): Custom API | Supabase | Firebase | None
NEXT_PUBLIC_AUTH_PROVIDER=Custom API

# Custom API: base URL used for auth AND every data request (admin + web).
# Leave EMPTY to run in zero-backend demo mode (mock auth + mock data);
# set it to switch the whole app to the real API automatically.
NEXT_PUBLIC_API_BASE_URL=

# Supabase (only if using the Supabase provider)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Firebase (only if using the Firebase provider)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
