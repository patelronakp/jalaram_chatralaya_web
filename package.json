{
  "name": "probietech-nextjs-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "setup-project": "ts-node scripts/setup-project.ts",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.12.12",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "webpack": "5.101.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
